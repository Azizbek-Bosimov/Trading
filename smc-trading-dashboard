<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SMC Trading Bot - XAUUSD/BTCUSD</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .signal-card { transition: all 0.3s ease; }
        .signal-card:hover { transform: translateY(-2px); box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); }
    </style>
</head>
<body class="bg-gradient-to-br from-gray-900 to-gray-800 text-white min-h-screen">
    <div class="container mx-auto px-4 py-8">
        <header class="text-center mb-12">
            <h1 class="text-5xl font-bold bg-gradient-to-r from-yellow-400 to-orange-500 bg-clip-text text-transparent mb-4">
                SMC Sniper Bot
            </h1>
            <p class="text-xl text-gray-300">XAUUSD & BTCUSD | 80% Win Rate | 3 TPs | Live Signals</p>
            <div class="flex justify-center gap-4 mt-6">
                <div class="bg-green-500 px-4 py-2 rounded-full text-sm font-bold">Status: <span id="botStatus">Running</span></div>
                <div class="bg-blue-500 px-4 py-2 rounded-full text-sm font-bold">Last Update: <span id="lastUpdate">--</span></div>
            </div>
        </header>

        <div id="signals" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
            <!-- Signals will be populated by JS -->
        </div>

        <div class="text-center">
            <a href="https://smc-bot.onrender.com/api/status" target="_blank" class="bg-gradient-to-r from-purple-500 to-pink-500 hover:from-purple-600 hover:to-pink-600 px-8 py-4 rounded-full font-bold text-lg transition-all duration-300">
                Backend Status & Logs
            </a>
        </div>
    </div>

    <script>
        async function fetchSignals() {
            try {
                const response = await fetch('https://smc-bot.onrender.com/api/signals');
                const signals = await response.json();
                
                document.getElementById('lastUpdate').textContent = new Date().toLocaleTimeString();
                document.getElementById('botStatus').textContent = 'Running';
                document.getElementById('botStatus').parentElement.className = 'bg-green-500 px-4 py-2 rounded-full text-sm font-bold';
                
                const signalsDiv = document.getElementById('signals');
                signalsDiv.innerHTML = signals.map(signal => `
                    <div class="signal-card bg-gray-800/50 backdrop-blur-sm border border-gray-700 rounded-2xl p-6">
                        <div class="flex items-center justify-between mb-4">
                            <h3 class="text-2xl font-bold">${signal.symbol}</h3>
                            <span class="px-3 py-1 rounded-full text-xs font-bold ${
                                signal.confidence > 80 ? 'bg-emerald-500' : 
                                signal.confidence > 60 ? 'bg-blue-500' : 'bg-yellow-500'
                            }">${signal.confidence}%</span>
                        </div>
                        <div class="space-y-2 text-sm">
                            <div><span class="font-semibold">Direction:</span> ${signal.direction}</div>
                            <div><span class="font-semibold">Entry:</span> ${signal.entry}</div>
                            <div><span class="font-semibold">SL:</span> ${signal.stopLoss}</div>
                            <div class="grid grid-cols-3 gap-2 mt-4">
                                <div class="bg-gradient-to-r from-green-500 to-green-600 p-2 rounded-lg text-center font-bold">TP1<br>${signal.tp1}</div>
                                <div class="bg-gradient-to-r from-green-600 to-green-700 p-2 rounded-lg text-center font-bold">TP2<br>${signal.tp2}</div>
                                <div class="bg-gradient-to-r from-green-700 to-green-800 p-2 rounded-lg text-center font-bold">TP3<br>${signal.tp3}</div>
                            </div>
                            <div class="mt-4 p-3 bg-gray-700/50 rounded-xl text-xs">
                                <strong>Confluence:</strong> OB:${signal.ob}% FVG:${signal.fvg}% Liq:${signal.liquidity}%
                            </div>
                        </div>
                    </div>
                `).join('');
            } catch (error) {
                document.getElementById('botStatus').textContent = 'Error';
                document.getElementById('botStatus').parentElement.className = 'bg-red-500 px-4 py-2 rounded-full text-sm font-bold';
            }
        }

        // Update every 30 seconds
        fetchSignals();
        setInterval(fetchSignals, 30000);
    </script>
</body>
</html>
